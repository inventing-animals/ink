<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Ink.Demo.ViewModels"
             xmlns:ink="clr-namespace:Ink.UI.Controls;assembly=Ink.UI"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Ink.Demo.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid ColumnDefinitions="160,*">

    <!-- Nav sidebar -->
    <Border Grid.Column="0"
            Background="{DynamicResource Ink.Brush.Surface.Panel}"
            BorderBrush="{DynamicResource Ink.Brush.Border.Subtle}"
            BorderThickness="0,0,1,0">
      <DockPanel Margin="8">
        <!-- Theme toggle pinned to bottom -->
        <ink:Button DockPanel.Dock="Bottom"
                Command="{Binding ToggleThemeCommand}"
                Content="{Binding ThemeLabel}"
                Margin="0,4,0,8" />
        <!-- Nav links -->
        <StackPanel Spacing="4">
          <TextBlock Text="Ink UI"
                     Margin="8,12,8,12" />
          <ink:Button Command="{Binding NavigateCommand}" CommandParameter="/buttons">Buttons</ink:Button>
          <ink:Button Command="{Binding NavigateCommand}" CommandParameter="/palette">Palette</ink:Button>
          <ink:Button Command="{Binding NavigateCommand}" CommandParameter="/router">Router</ink:Button>
          <ink:Button Command="{Binding NavigateCommand}" CommandParameter="/windows">Windows</ink:Button>
          <ink:Button Command="{Binding NavigateCommand}" CommandParameter="/datagrid">DataGrid</ink:Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Page content -->
    <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" />

  </Grid>
</UserControl>
