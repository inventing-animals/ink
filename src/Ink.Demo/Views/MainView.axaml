<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Ink.Demo.ViewModels"
             xmlns:ink="clr-namespace:Ink.UI.Controls;assembly=Ink.UI"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Ink.Demo.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid ColumnDefinitions="160,*">

    <!-- Nav sidebar -->
    <Border Grid.Column="0"
            Background="{DynamicResource Ink.Brush.Surface.Panel}"
            BorderBrush="{DynamicResource Ink.Brush.Border.Subtle}"
            BorderThickness="0,0,1,0">
      <StackPanel Spacing="4" Margin="8">
        <TextBlock Text="Ink UI"
                   Margin="8,12,8,12" />
        <Button Command="{Binding NavigateCommand}" CommandParameter="/buttons">Buttons</Button>
        <Button Command="{Binding NavigateCommand}" CommandParameter="/palette">Palette</Button>
        <Button Command="{Binding NavigateCommand}" CommandParameter="/router">Router</Button>
      </StackPanel>
    </Border>

    <!-- Page content -->
    <ScrollViewer Grid.Column="1">
      <ContentControl Content="{Binding CurrentPage}" Margin="24" />
    </ScrollViewer>

  </Grid>
</UserControl>
