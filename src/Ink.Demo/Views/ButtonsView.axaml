<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             xmlns:ink="clr-namespace:Ink.UI.Controls;assembly=Ink.UI"
             x:Class="Ink.Demo.Views.ButtonsView"
             x:DataType="vm:ButtonsViewModel">
  <ScrollViewer>
  <StackPanel Spacing="24" Margin="24">
    <TextBlock Text="Buttons" />

    <StackPanel Spacing="8">
      <TextBlock Text="Variants" />
      <WrapPanel>
        <Button Margin="0,0,8,8">Secondary</Button>
        <Button ink:ButtonAssist.Variant="Primary" Margin="0,0,8,8">Primary</Button>
        <Button ink:ButtonAssist.Variant="Danger" Margin="0,0,8,8">Danger</Button>
        <Button ink:ButtonAssist.Variant="Ghost" Margin="0,0,8,8" IsEnabled="False">Ghost (WIP)</Button>
      </WrapPanel>
    </StackPanel>

    <StackPanel Spacing="8">
      <TextBlock Text="Disabled" />
      <WrapPanel>
        <Button IsEnabled="False" Margin="0,0,8,8">Secondary</Button>
        <Button ink:ButtonAssist.Variant="Primary" IsEnabled="False" Margin="0,0,8,8">Primary</Button>
        <Button ink:ButtonAssist.Variant="Danger" IsEnabled="False" Margin="0,0,8,8">Danger</Button>
      </WrapPanel>
    </StackPanel>
  </StackPanel>
  </ScrollViewer>
</UserControl>
