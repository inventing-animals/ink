<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             xmlns:demo="using:Ink.Demo.Views"
             xmlns:ink="clr-namespace:Ink.UI.Controls;assembly=Ink.UI"
             xmlns:fa="using:Ink.FontAwesome"
             x:Class="Ink.Demo.Views.CheckboxView"
             x:DataType="vm:CheckboxViewModel">
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <demo:PageToolbar />

      <StackPanel Spacing="8" IsVisible="{Binding SelectedSubpage, Converter={StaticResource InkEqualsConverter}, ConverterParameter=Ink}">
        <TextBlock Classes="h4" Text="ink:CheckBox - States" />
        <StackPanel Spacing="4">
          <ink:CheckBox>Unchecked</ink:CheckBox>
          <ink:CheckBox IsChecked="True">Checked</ink:CheckBox>
          <ink:CheckBox IsThreeState="True" IsChecked="{x:Null}">Indeterminate</ink:CheckBox>
          <ink:CheckBox IsEnabled="False">Disabled (unchecked)</ink:CheckBox>
          <ink:CheckBox IsEnabled="False" IsChecked="True">Disabled (checked)</ink:CheckBox>
        </StackPanel>
        <TextBlock Classes="h4" Text="ink:CheckBox - Rich labels" />
        <TextBlock Classes="small muted" Text="Checkbox labels can include icons and layout when you want more expressive option rows." />
        <StackPanel Spacing="6">
          <ink:CheckBox IsChecked="True">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <fa:FontAwesomeIcon Icon="{x:Static fa:Icon.Bell}" Face="ClassicSolid" />
              <TextBlock Text="Send activity notifications" />
            </StackPanel>
          </ink:CheckBox>
          <ink:CheckBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <fa:FontAwesomeIcon Icon="{x:Static fa:Icon.Calendar}" Face="ClassicRegular" />
              <TextBlock Text="Sync calendar reminders" />
            </StackPanel>
          </ink:CheckBox>
          <ink:CheckBox IsThreeState="True" IsChecked="{x:Null}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <fa:FontAwesomeIcon Icon="{x:Static fa:Icon.ChartLine}" Face="ClassicSolid" />
              <TextBlock Text="Analytics consent (inherit from workspace)" />
            </StackPanel>
          </ink:CheckBox>
        </StackPanel>
      </StackPanel>

      <StackPanel Spacing="8" IsVisible="{Binding SelectedSubpage, Converter={StaticResource InkEqualsConverter}, ConverterParameter=Avalonia}">
        <TextBlock Classes="h4" Text="Avalonia CheckBox (themed)" />
        <TextBlock Classes="small muted" Text="Plain Avalonia CheckBox with Ink base theme applied." />
        <StackPanel Spacing="4">
          <CheckBox>Unchecked</CheckBox>
          <CheckBox IsChecked="True">Checked</CheckBox>
          <CheckBox IsThreeState="True" IsChecked="{x:Null}">Indeterminate</CheckBox>
          <CheckBox IsEnabled="False">Disabled (unchecked)</CheckBox>
          <CheckBox IsEnabled="False" IsChecked="True">Disabled (checked)</CheckBox>
        </StackPanel>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
