<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             xmlns:demo="using:Ink.Demo.Views"
             xmlns:ink="clr-namespace:Ink.UI.Controls;assembly=Ink.UI"
             x:Class="Ink.Demo.Views.ToggleView"
             x:DataType="vm:ToggleViewModel">
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <demo:PageToolbar />

      <StackPanel Spacing="8" IsVisible="{Binding SelectedSubpage, Converter={StaticResource InkEqualsConverter}, ConverterParameter=Ink}">
        <TextBlock Classes="h4" Text="ink:ToggleButton - Variants" />
        <TextBlock Classes="small muted" Text="Stateful button with the same variant API as ink:Button." />
        <WrapPanel>
          <ink:ToggleButton Margin="0,0,8,8">Default</ink:ToggleButton>
          <ink:ToggleButton IsChecked="True" Margin="0,0,8,8">Default</ink:ToggleButton>
          <ink:ToggleButton Variant="Ghost" Margin="0,0,8,8">Ghost</ink:ToggleButton>
          <ink:ToggleButton Variant="Ghost" IsChecked="True" Margin="0,0,8,8">Ghost</ink:ToggleButton>
        </WrapPanel>
        <TextBlock Classes="h4" Text="ink:ToggleButton - Disabled" />
        <WrapPanel>
          <ink:ToggleButton IsEnabled="False" Margin="0,0,8,8">Disabled</ink:ToggleButton>
          <ink:ToggleButton IsChecked="True" IsEnabled="False" Margin="0,0,8,8">Selected</ink:ToggleButton>
          <ink:ToggleButton Variant="Ghost" IsChecked="True" IsEnabled="False" Margin="0,0,8,8">Ghost</ink:ToggleButton>
        </WrapPanel>
      </StackPanel>

      <StackPanel Spacing="8" IsVisible="{Binding SelectedSubpage, Converter={StaticResource InkEqualsConverter}, ConverterParameter=Avalonia}">
        <TextBlock Classes="h4" Text="Avalonia ToggleButton (themed)" />
        <TextBlock Classes="small muted" Text="Plain Avalonia ToggleButton with the Ink toggle button theme applied." />
        <WrapPanel>
          <ToggleButton Margin="0,0,8,8">Off</ToggleButton>
          <ToggleButton IsChecked="True" Margin="0,0,8,8">On</ToggleButton>
          <ToggleButton IsEnabled="False" Margin="0,0,8,8">Disabled</ToggleButton>
        </WrapPanel>
        <TextBlock Classes="h4" Text="Avalonia ToggleSwitch" />
        <TextBlock Classes="small muted" Text="No ToggleSwitch theme is currently registered, so this sample is hidden to avoid template-part crashes." />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
