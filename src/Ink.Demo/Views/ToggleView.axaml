<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             x:Class="Ink.Demo.Views.ToggleView"
             x:DataType="vm:ToggleViewModel">
  <!-- TODO: Subclass ink:ToggleSwitch from Avalonia ToggleSwitch and use it here instead -->
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <TextBlock Text="Toggle" />

      <StackPanel Spacing="8">
        <TextBlock Text="Avalonia ToggleSwitch" />
        <TextBlock Text="Not yet themed - requires Ink template implementation."
                   Foreground="{DynamicResource Ink.Brush.Content.Muted}"
                   FontSize="12" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Text="Avalonia ToggleButton (themed)" />
        <WrapPanel>
          <ToggleButton Margin="0,0,8,8">Off</ToggleButton>
          <ToggleButton IsChecked="True" Margin="0,0,8,8">On</ToggleButton>
          <ToggleButton IsEnabled="False" Margin="0,0,8,8">Disabled</ToggleButton>
        </WrapPanel>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
