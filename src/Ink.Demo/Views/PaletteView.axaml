          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Green.500}">
            <TextBlock Text="500" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Green.Foreground.Subtle}" />
