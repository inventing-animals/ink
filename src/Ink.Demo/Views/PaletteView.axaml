<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             x:Class="Ink.Demo.Views.PaletteView"
             x:DataType="vm:PaletteViewModel">
  <ScrollViewer>
  <StackPanel Spacing="32" Margin="24">
    <TextBlock Text="Palette" />

    <!-- Surfaces -->
    <StackPanel Spacing="8">
      <TextBlock Text="Surfaces" />
      <WrapPanel>
        <Border Width="80" Height="48" Margin="0,0,8,8" CornerRadius="6"
                Background="{DynamicResource Ink.Brush.Surface.Canvas}"
                BorderBrush="{DynamicResource Ink.Brush.Border.Subtle}" BorderThickness="1">
          <TextBlock Text="Canvas" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Border Width="80" Height="48" Margin="0,0,8,8" CornerRadius="6"
                Background="{DynamicResource Ink.Brush.Surface.Panel}"
                BorderBrush="{DynamicResource Ink.Brush.Border.Subtle}" BorderThickness="1">
          <TextBlock Text="Panel" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Border Width="80" Height="48" Margin="0,0,8,8" CornerRadius="6"
                Background="{DynamicResource Ink.Brush.Surface.Raised}"
                BorderBrush="{DynamicResource Ink.Brush.Border.Subtle}" BorderThickness="1">
          <TextBlock Text="Raised" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Border Width="80" Height="48" Margin="0,0,8,8" CornerRadius="6"
                Background="{DynamicResource Ink.Brush.Surface.Overlay.Subtle}"
                BorderBrush="{DynamicResource Ink.Brush.Border.Subtle}" BorderThickness="1">
          <TextBlock Text="Overlay" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </WrapPanel>
    </StackPanel>

    <!-- Accent -->
    <StackPanel Spacing="8">
      <TextBlock Text="Accent" />
      <WrapPanel>
        <Border Width="80" Height="48" Margin="0,0,8,8" CornerRadius="6"
                Background="{DynamicResource Ink.Brush.Accent}">
          <TextBlock Text="Accent" Foreground="{DynamicResource Ink.Brush.Accent.Content}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Border Width="80" Height="48" Margin="0,0,8,8" CornerRadius="6"
                Background="{DynamicResource Ink.Brush.Accent.Hover}">
          <TextBlock Text="Hover" Foreground="{DynamicResource Ink.Brush.Accent.Content}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Border Width="80" Height="48" Margin="0,0,8,8" CornerRadius="6"
                Background="{DynamicResource Ink.Brush.Accent.Subtle}"
                BorderBrush="{DynamicResource Ink.Brush.Border.Subtle}" BorderThickness="1">
          <TextBlock Text="Subtle" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </WrapPanel>
    </StackPanel>

    <!-- Danger -->
    <StackPanel Spacing="8">
      <TextBlock Text="Danger" />
      <WrapPanel>
        <Border Width="80" Height="48" Margin="0,0,8,8" CornerRadius="6"
                Background="{DynamicResource Ink.Brush.Danger}">
          <TextBlock Text="Danger" Foreground="{DynamicResource Ink.Brush.Danger.Content}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Border Width="80" Height="48" Margin="0,0,8,8" CornerRadius="6"
                Background="{DynamicResource Ink.Brush.Danger.Hover}">
          <TextBlock Text="Hover" Foreground="{DynamicResource Ink.Brush.Danger.Content}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Border Width="80" Height="48" Margin="0,0,8,8" CornerRadius="6"
                Background="{DynamicResource Ink.Brush.Danger.Subtle}"
                BorderBrush="{DynamicResource Ink.Brush.Border.Subtle}" BorderThickness="1">
          <TextBlock Text="Subtle" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </WrapPanel>
    </StackPanel>

    <!-- Content -->
    <StackPanel Spacing="8">
      <TextBlock Text="Content" />
      <StackPanel Spacing="4">
        <TextBlock Text="Primary"   Foreground="{DynamicResource Ink.Brush.Content.Primary}" />
        <TextBlock Text="Secondary" Foreground="{DynamicResource Ink.Brush.Content.Secondary}" />
        <TextBlock Text="Muted"     Foreground="{DynamicResource Ink.Brush.Content.Muted}" />
        <TextBlock Text="Disabled"  Foreground="{DynamicResource Ink.Brush.Content.Disabled}" />
      </StackPanel>
    </StackPanel>

    <!-- Named Colors -->
    <StackPanel Spacing="24">
      <TextBlock Text="Named Colors" />

      <!-- Relative (theme-aware) -->
      <StackPanel Spacing="16">
        <StackPanel Spacing="2">
          <TextBlock Text="Ink.Color.*" />
          <TextBlock Text="Theme-aware: scale inverts in dark mode so shade numbers preserve visual weight."
                     Foreground="{DynamicResource Ink.Brush.Content.Muted}" FontSize="11" />
        </StackPanel>

      <!-- Gray -->
      <StackPanel Spacing="4">
        <TextBlock Text="Gray" Foreground="{DynamicResource Ink.Brush.Content.Secondary}" />
        <StackPanel Orientation="Horizontal" Spacing="3">
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Gray.50}">
            <TextBlock Text="50"  FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Gray.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Gray.100}">
            <TextBlock Text="100" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Gray.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Gray.200}">
            <TextBlock Text="200" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Gray.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Gray.300}">
            <TextBlock Text="300" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Gray.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Gray.400}">
            <TextBlock Text="400" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Gray.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Gray.500}">
            <TextBlock Text="500" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Gray.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Gray.600}">
            <TextBlock Text="600" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Gray.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Gray.700}">
            <TextBlock Text="700" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Gray.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Gray.800}">
            <TextBlock Text="800" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Gray.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Gray.900}">
            <TextBlock Text="900" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Gray.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Gray.950}">
            <TextBlock Text="950" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Gray.Foreground.Subtle}" />
          </Border>
        </StackPanel>
      </StackPanel>

      <!-- Blue -->
      <StackPanel Spacing="4">
