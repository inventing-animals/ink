            <TextBlock Text="700" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Green.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Green.800}">
            <TextBlock Text="800" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Green.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Green.900}">
            <TextBlock Text="900" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Green.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Green.950}">
            <TextBlock Text="950" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Green.Foreground.Subtle}" />
          </Border>
        </StackPanel>
      </StackPanel>

