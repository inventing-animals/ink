          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Lime.400}">
            <TextBlock Text="400" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Lime.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Lime.500}">
            <TextBlock Text="500" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Lime.Foreground.Subtle}" />
