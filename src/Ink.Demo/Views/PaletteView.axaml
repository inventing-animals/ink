        <TextBlock Text="Yellow" Foreground="{DynamicResource Ink.Brush.Content.Secondary}" />
        <StackPanel Orientation="Horizontal" Spacing="3">
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Yellow.50}">
            <TextBlock Text="50"  FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Yellow.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Yellow.100}">
            <TextBlock Text="100" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Yellow.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Yellow.200}">
            <TextBlock Text="200" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Yellow.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Yellow.300}">
            <TextBlock Text="300" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Yellow.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Yellow.400}">
            <TextBlock Text="400" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Yellow.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Yellow.500}">
            <TextBlock Text="500" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Yellow.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Yellow.600}">
            <TextBlock Text="600" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Yellow.Foreground.Subtle}" />
          </Border>
