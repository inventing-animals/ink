          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Lime.600}">
            <TextBlock Text="600" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Lime.Foreground.Subtle}" />
