          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Lime.800}">
            <TextBlock Text="800" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Lime.Foreground.Subtle}" />
