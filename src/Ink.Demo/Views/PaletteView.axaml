        <TextBlock Text="Red" Foreground="{DynamicResource Ink.Brush.Content.Secondary}" />
        <StackPanel Orientation="Horizontal" Spacing="3">
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Red.50}">
            <TextBlock Text="50"  FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Red.Foreground}" />
