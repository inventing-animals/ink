      <!-- Lime -->
      <StackPanel Spacing="4">
        <TextBlock Text="Lime" Foreground="{DynamicResource Ink.Brush.Content.Secondary}" />
        <StackPanel Orientation="Horizontal" Spacing="3">
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Lime.50}">
