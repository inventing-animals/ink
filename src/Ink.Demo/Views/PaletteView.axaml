        <StackPanel Orientation="Horizontal" Spacing="3">
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Blue.50}">
            <TextBlock Text="50"  FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Blue.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Blue.100}">
            <TextBlock Text="100" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Blue.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Blue.200}">
            <TextBlock Text="200" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Blue.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Blue.300}">
            <TextBlock Text="300" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Blue.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Blue.400}">
            <TextBlock Text="400" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Blue.Foreground}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Blue.500}">
            <TextBlock Text="500" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Blue.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Blue.600}">
            <TextBlock Text="600" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Blue.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Blue.700}">
            <TextBlock Text="700" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Blue.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Blue.800}">
            <TextBlock Text="800" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Blue.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Blue.900}">
            <TextBlock Text="900" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Blue.Foreground.Subtle}" />
          </Border>
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Blue.950}">
            <TextBlock Text="950" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Ink.Color.Blue.Foreground.Subtle}" />
          </Border>
        </StackPanel>
      </StackPanel>

      <!-- Green -->
      <StackPanel Spacing="4">
        <TextBlock Text="Green" Foreground="{DynamicResource Ink.Brush.Content.Secondary}" />
        <StackPanel Orientation="Horizontal" Spacing="3">
          <Border Width="52" Height="52" CornerRadius="4" Background="{DynamicResource Ink.Color.Green.50}">
