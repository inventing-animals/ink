<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             x:Class="Ink.Demo.Views.ComboBoxView"
             x:DataType="vm:ComboBoxViewModel">
  <!-- TODO: Subclass ink:ComboBox from Avalonia ComboBox and use it here instead -->
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <TextBlock Text="ComboBox" />

      <StackPanel Spacing="8">
        <TextBlock Text="Avalonia ComboBox (themed)" />
        <TextBlock Text="Plain Avalonia ComboBox with Ink base theme applied - no subclass yet."
                   Foreground="{DynamicResource Ink.Brush.Content.Muted}"
                   FontSize="12" />
        <ComboBox SelectedIndex="0" Width="200" HorizontalAlignment="Left">
          <ComboBoxItem>Option A</ComboBoxItem>
          <ComboBoxItem>Option B</ComboBoxItem>
          <ComboBoxItem>Option C</ComboBoxItem>
        </ComboBox>
        <ComboBox SelectedIndex="0" Width="200" HorizontalAlignment="Left" IsEnabled="False">
          <ComboBoxItem>Disabled</ComboBoxItem>
        </ComboBox>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
