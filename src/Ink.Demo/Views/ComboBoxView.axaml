<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             xmlns:ink="clr-namespace:Ink.UI.Controls;assembly=Ink.UI"
             xmlns:demo="using:Ink.Demo.Views"
             x:Class="Ink.Demo.Views.ComboBoxView"
             x:DataType="vm:ComboBoxViewModel">
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <demo:PageToolbar />
      
      <StackPanel Spacing="8" IsVisible="{Binding SelectedSubpage, Converter={StaticResource InkEqualsConverter}, ConverterParameter=Ink}">
        <TextBlock Classes="h4" Text="Default" />
        <ink:ComboBox SelectedIndex="0" Width="200" HorizontalAlignment="Left">
          <ComboBoxItem>Option A</ComboBoxItem>
          <ComboBoxItem>Option B</ComboBoxItem>
          <ComboBoxItem>Option C</ComboBoxItem>
        </ink:ComboBox>
      </StackPanel>

      <StackPanel Spacing="8" IsVisible="{Binding SelectedSubpage, Converter={StaticResource InkEqualsConverter}, ConverterParameter=Ink}">
        <TextBlock Classes="h4" Text="Placeholder" />
        <ink:ComboBox Width="200" HorizontalAlignment="Left" PlaceholderText="Choose an option">
          <ComboBoxItem>Option A</ComboBoxItem>
          <ComboBoxItem>Option B</ComboBoxItem>
          <ComboBoxItem>Option C</ComboBoxItem>
        </ink:ComboBox>
      </StackPanel>

      <StackPanel Spacing="8" IsVisible="{Binding SelectedSubpage, Converter={StaticResource InkEqualsConverter}, ConverterParameter=Ink}">
        <TextBlock Classes="h4" Text="Disabled" />
        <ink:ComboBox SelectedIndex="0" Width="200" HorizontalAlignment="Left" IsEnabled="False">
          <ComboBoxItem>Disabled</ComboBoxItem>
        </ink:ComboBox>
      </StackPanel>

      <StackPanel Spacing="8" IsVisible="{Binding SelectedSubpage, Converter={StaticResource InkEqualsConverter}, ConverterParameter=Avalonia}">
        <TextBlock Classes="h4" Text="Standard Avalonia ComboBox (styled, no overlay)" />
        <TextBlock Classes="small muted" Text="Uses the Ink theme via auto-apply. Dropdown does not dim the window." />
        <ComboBox SelectedIndex="0" Width="200" HorizontalAlignment="Left">
          <ComboBoxItem>Option A</ComboBoxItem>
          <ComboBoxItem>Option B</ComboBoxItem>
          <ComboBoxItem>Option C</ComboBoxItem>
        </ComboBox>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
