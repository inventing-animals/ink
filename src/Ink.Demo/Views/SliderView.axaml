<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             x:Class="Ink.Demo.Views.SliderView"
             x:DataType="vm:SliderViewModel">
  <!-- TODO: Subclass ink:Slider from Avalonia Slider and use it here instead -->
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <TextBlock Text="Slider" />

      <StackPanel Spacing="8">
        <TextBlock Text="Avalonia Slider" />
        <TextBlock Text="Not yet themed - requires Ink template implementation."
                   Foreground="{DynamicResource Ink.Brush.Content.Muted}"
                   FontSize="12" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
