<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             x:Class="Ink.Demo.Views.SliderView"
             x:DataType="vm:SliderViewModel">
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <TextBlock Classes="h2" Text="Slider" />

      <StackPanel Spacing="8">
        <TextBlock Classes="h4" Text="Default" />
        <Slider Value="40" Width="300" HorizontalAlignment="Left" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Classes="h4" Text="Reversed" />
        <Slider Value="40" IsDirectionReversed="True" Width="300" HorizontalAlignment="Left" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Classes="h4" Text="Disabled" />
        <Slider Value="40" Width="300" HorizontalAlignment="Left" IsEnabled="False" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Classes="h4" Text="Vertical" />
        <Slider Value="40" Orientation="Vertical" Height="120" HorizontalAlignment="Left" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
