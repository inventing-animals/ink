<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             xmlns:demo="using:Ink.Demo.Views"
             xmlns:ink="clr-namespace:Ink.UI.Controls;assembly=Ink.UI"
             x:Class="Ink.Demo.Views.PopupsView"
             x:DataType="vm:PopupsViewModel">
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <demo:PageToolbar />

      <StackPanel Spacing="8" IsVisible="{Binding SelectedSubpage, Converter={StaticResource InkEqualsConverter}, ConverterParameter=Ink}">
        <TextBlock Classes="h4" Text="ink:ComboBox" />
        <TextBlock Classes="small muted" Text="Opening the dropdown dims the window behind it." />
        <ink:ComboBox SelectedIndex="0" Width="240" HorizontalAlignment="Left" PlaceholderText="Choose an option">
          <ComboBoxItem>Option A</ComboBoxItem>
          <ComboBoxItem>Option B</ComboBoxItem>
          <ComboBoxItem>Option C</ComboBoxItem>
          <ComboBoxItem>Option D</ComboBoxItem>
        </ink:ComboBox>
        <TextBlock Classes="h4" Text="Multiple ink:ComboBoxes" />
        <TextBlock Classes="small muted" Text="Each independently triggers the overlay." />
        <StackPanel Orientation="Horizontal" Spacing="12">
          <ink:ComboBox SelectedIndex="0" Width="160" PlaceholderText="First">
            <ComboBoxItem>Red</ComboBoxItem>
            <ComboBoxItem>Green</ComboBoxItem>
            <ComboBoxItem>Blue</ComboBoxItem>
          </ink:ComboBox>
          <ink:ComboBox SelectedIndex="0" Width="160" PlaceholderText="Second">
            <ComboBoxItem>Small</ComboBoxItem>
            <ComboBoxItem>Medium</ComboBoxItem>
            <ComboBoxItem>Large</ComboBoxItem>
          </ink:ComboBox>
        </StackPanel>
        <TextBlock Classes="h4" Text="ink:Flyout" />
        <TextBlock Classes="small muted" Text="Opening a flyout dims the window." />
        <ink:Button HorizontalAlignment="Left">
          <ink:Button.Flyout>
            <ink:Flyout>
              <StackPanel Spacing="12" Margin="16">
                <TextBlock Classes="large" Text="Flyout content" />
                <TextBlock Classes="small muted" Text="This is a flyout panel." />
                <ink:Button Content="Confirm" />
              </StackPanel>
            </ink:Flyout>
          </ink:Button.Flyout>
          Open Flyout
        </ink:Button>
        <TextBlock Classes="h4" Text="Nested overlay dismissal" />
        <TextBlock Classes="small muted" Text="Flyout contains a ComboBox. Clicking the overlay closes the ComboBox first, then a second click closes the flyout." />
        <ink:Button HorizontalAlignment="Left">
          <ink:Button.Flyout>
            <ink:Flyout>
              <StackPanel Spacing="12" Margin="16">
                <TextBlock Classes="large" Text="Flyout with ComboBox" />
                <TextBlock Classes="small muted" Text="Open the dropdown, then click the overlay." />
                <ink:ComboBox SelectedIndex="0" Width="200" PlaceholderText="Pick one">
                  <ComboBoxItem>Alpha</ComboBoxItem>
                  <ComboBoxItem>Beta</ComboBoxItem>
                  <ComboBoxItem>Gamma</ComboBoxItem>
                </ink:ComboBox>
              </StackPanel>
            </ink:Flyout>
          </ink:Button.Flyout>
          Open Flyout
        </ink:Button>
        <TextBlock Classes="h4" Text="ink:PopupHeader in Flyout" />
        <TextBlock Classes="small muted" Text="PopupHeader provides a title, description, and close button at the top of a flyout." />
        <ink:Button HorizontalAlignment="Left">
          <ink:Button.Flyout>
            <ink:Flyout>
              <StackPanel>
                <ink:PopupHeader Title="Filter options" Description="Narrow down your results" />
                <StackPanel Spacing="12" Margin="16">
                  <ink:CheckBox Content="Show archived" />
                  <ink:CheckBox Content="Show drafts" />
                  <ink:CheckBox Content="Show deleted" />
                  <ink:Button Content="Apply" Classes="ink-primary" />
                </StackPanel>
              </StackPanel>
            </ink:Flyout>
          </ink:Button.Flyout>
          Open Flyout
        </ink:Button>
        <TextBlock Classes="h4" Text="ink:PopupHeader in ComboBox" />
        <TextBlock Classes="small muted" Text="PopupHeader sits above the items list in the dropdown." />
        <ink:ComboBox Width="240" HorizontalAlignment="Left" PlaceholderText="Choose a role">
          <ink:ComboBox.PopupHeader>
            <ink:PopupHeader Title="Select role" Description="Assigns permissions for this user" />
          </ink:ComboBox.PopupHeader>
          <ComboBoxItem>Viewer</ComboBoxItem>
          <ComboBoxItem>Editor</ComboBoxItem>
          <ComboBoxItem>Admin</ComboBoxItem>
          <ComboBoxItem>Owner</ComboBoxItem>
        </ink:ComboBox>
      </StackPanel>

      <StackPanel Spacing="8" IsVisible="{Binding SelectedSubpage, Converter={StaticResource InkEqualsConverter}, ConverterParameter=Avalonia}">
        <TextBlock Classes="h4" Text="Avalonia ComboBox (themed)" />
        <ComboBox SelectedIndex="0" Width="240" HorizontalAlignment="Left" PlaceholderText="Choose an option">
          <ComboBoxItem>Option A</ComboBoxItem>
          <ComboBoxItem>Option B</ComboBoxItem>
          <ComboBoxItem>Option C</ComboBoxItem>
        </ComboBox>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
