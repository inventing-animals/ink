<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             x:Class="Ink.Demo.Views.CalendarView"
             x:DataType="vm:CalendarViewModel">
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <TextBlock Classes="h2" Text="Calendar" />

      <StackPanel Spacing="8">
        <TextBlock Classes="h4" Text="Default" />
        <Calendar />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Classes="h4" Text="Multi-select" />
        <Calendar SelectionMode="MultipleRange" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
