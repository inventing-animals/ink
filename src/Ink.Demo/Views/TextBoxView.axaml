<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             x:Class="Ink.Demo.Views.TextBoxView"
             x:DataType="vm:TextBoxViewModel">
  <!-- TODO: Subclass ink:TextBox from Avalonia TextBox and use it here instead -->
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <TextBlock Text="TextBox" />

      <StackPanel Spacing="8">
        <TextBlock Text="Avalonia TextBox (themed)" />
        <TextBlock Text="Plain Avalonia TextBox with Ink base theme applied - no subclass yet."
                   Foreground="{DynamicResource Ink.Brush.Content.Muted}"
                   FontSize="12" />
        <TextBox Width="240" HorizontalAlignment="Left" Watermark="Placeholder..." />
        <TextBox Width="240" HorizontalAlignment="Left" Text="Filled value" />
        <TextBox Width="240" HorizontalAlignment="Left" IsEnabled="False" Watermark="Disabled" />
        <TextBox Width="240" HorizontalAlignment="Left" IsReadOnly="True" Text="Read only" />
        <TextBox Width="240" HorizontalAlignment="Left" AcceptsReturn="True" TextWrapping="Wrap"
                 Height="80" Watermark="Multiline..." />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
