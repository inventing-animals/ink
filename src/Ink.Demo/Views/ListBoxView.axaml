<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             x:Class="Ink.Demo.Views.ListBoxView"
             x:DataType="vm:ListBoxViewModel">
  <!-- TODO: Subclass ink:ListBox and ink:ListBoxItem from Avalonia equivalents and use them here instead -->
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <TextBlock Classes="h2" Text="ListBox" />

      <StackPanel Spacing="8">
        <TextBlock Classes="h4" Text="Avalonia ListBox / ListBoxItem" />
        <TextBlock Classes="small muted" Text="Not yet themed - requires Ink template implementation." />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
