<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             xmlns:ink="clr-namespace:Ink.UI.Controls;assembly=Ink.UI"
             x:Class="Ink.Demo.Views.WindowsDemoView"
             x:DataType="vm:WindowsDemoViewModel">
  <ScrollViewer>
  <StackPanel Spacing="24" Margin="24">
    <TextBlock Text="Window Service" />

    <StackPanel Spacing="8">
      <TextBlock Text="Open a secondary surface"
                 Foreground="{DynamicResource Ink.Brush.Content.Secondary}" />
      <TextBlock Text="Window — new OS window on desktop · drawer on mobile · browser tab on web"
                 Foreground="{DynamicResource Ink.Brush.Content.Muted}"
                 FontSize="12" />
      <ink:Button Variant="Primary"
                  Command="{Binding OpenWindowCommand}"
                  Margin="0,4,0,0">
        Open Window
      </ink:Button>
    </StackPanel>

    <StackPanel Spacing="8">
      <TextBlock Text="Open as a tab"
                 Foreground="{DynamicResource Ink.Brush.Content.Secondary}" />
      <TextBlock Text="Tab — tab in current window on desktop · drawer on mobile · browser tab on web"
                 Foreground="{DynamicResource Ink.Brush.Content.Muted}"
                 FontSize="12" />
      <ink:Button Command="{Binding OpenTabCommand}"
                  Margin="0,4,0,0">
        Open Tab
      </ink:Button>
    </StackPanel>

  </StackPanel>
  </ScrollViewer>
</UserControl>
