<ink:DesktopWindow xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ink="clr-namespace:Ink.UI.Controls;assembly=Ink.UI"
                  xmlns:vm="using:Ink.Demo.ViewModels"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:views="using:Ink.Demo.Views"
                  mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                  x:Class="Ink.Demo.Views.MainWindow"
                  Icon="/Assets/avalonia-logo.ico"
                  Title="Ink.UI"
                  Width="1024" Height="768"
                  MinWidth="480" MinHeight="320">
    <views:MainView />
</ink:DesktopWindow>
