<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ink.Demo.ViewModels"
             xmlns:ink="clr-namespace:Ink.UI.Controls;assembly=Ink.UI"
             xmlns:fa="using:Ink.FontAwesome"
             xmlns:demo="using:Ink.Demo.Views"
             x:Class="Ink.Demo.Views.TabStripView"
             x:DataType="vm:TabStripViewModel">
  <ScrollViewer>
    <StackPanel Spacing="24" Margin="24">
      <demo:PageToolbar />

      <StackPanel Spacing="8">
        <TextBlock Classes="h4" Text="Basic TabStrip" />
        <TextBlock Classes="small muted"
                   Text="TabStrip is a navigation primitive - a row of selectable tab headers. Pair with a ContentControl to display tab content." />
        <ink:TabStrip SelectedIndex="0">
          <ink:TabStripItem Content="Overview" />
          <ink:TabStripItem Content="Details" />
          <ink:TabStripItem Content="Activity" />
          <ink:TabStripItem Content="Settings" />
        </ink:TabStrip>
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Classes="h4" Text="With icons" />
        <TextBlock Classes="small muted" Text="Tab labels can use rich content, which works well for app sections and tool panes." />
        <ink:TabStrip SelectedIndex="0">
          <ink:TabStripItem>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <fa:FontAwesomeIcon Icon="{x:Static fa:Icon.House}" Face="ClassicSolid" />
              <TextBlock Text="Overview" />
            </StackPanel>
          </ink:TabStripItem>
          <ink:TabStripItem>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <fa:FontAwesomeIcon Icon="{x:Static fa:Icon.ChartLine}" Face="ClassicSolid" />
              <TextBlock Text="Reports" />
            </StackPanel>
          </ink:TabStripItem>
          <ink:TabStripItem>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <fa:FontAwesomeIcon Icon="{x:Static fa:Icon.UsersGear}" Face="ClassicSolid" />
              <TextBlock Text="Team" />
            </StackPanel>
          </ink:TabStripItem>
          <ink:TabStripItem>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <fa:FontAwesomeIcon Icon="{x:Static fa:Icon.Gear}" Face="ClassicSolid" />
              <TextBlock Text="Settings" />
            </StackPanel>
          </ink:TabStripItem>
        </ink:TabStrip>
        <TextBlock Classes="small muted" Text="Glyph-only tabs are useful when space is tight and the icons are already familiar." />
        <ink:TabStrip SelectedIndex="0">
          <ink:TabStripItem ToolTip.Tip="Overview">
            <Grid Width="16" Height="16">
              <fa:FontAwesomeIcon Icon="{x:Static fa:Icon.House}" Face="ClassicSolid" />
            </Grid>
          </ink:TabStripItem>
          <ink:TabStripItem ToolTip.Tip="Reports">
            <Grid Width="16" Height="16">
              <fa:FontAwesomeIcon Icon="{x:Static fa:Icon.ChartLine}" Face="ClassicSolid" />
            </Grid>
          </ink:TabStripItem>
          <ink:TabStripItem ToolTip.Tip="Team">
            <Grid Width="16" Height="16">
              <fa:FontAwesomeIcon Icon="{x:Static fa:Icon.UsersGear}" Face="ClassicSolid" />
            </Grid>
          </ink:TabStripItem>
          <ink:TabStripItem ToolTip.Tip="Settings">
            <Grid Width="16" Height="16">
              <fa:FontAwesomeIcon Icon="{x:Static fa:Icon.Gear}" Face="ClassicSolid" />
            </Grid>
          </ink:TabStripItem>
        </ink:TabStrip>
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Classes="h4" Text="With many items (scrollable)" />
        <ink:TabStrip SelectedIndex="0">
          <ink:TabStripItem Content="General" />
          <ink:TabStripItem Content="Account" />
          <ink:TabStripItem Content="Notifications" />
          <ink:TabStripItem Content="Privacy" />
          <ink:TabStripItem Content="Security" />
          <ink:TabStripItem Content="Integrations" />
          <ink:TabStripItem Content="Billing" />
          <ink:TabStripItem Content="Advanced" />
        </ink:TabStrip>
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Classes="h4" Text="With disabled item" />
        <ink:TabStrip SelectedIndex="0">
          <ink:TabStripItem Content="Active" />
          <ink:TabStripItem Content="Preview" />
          <ink:TabStripItem Content="Locked" IsEnabled="False" />
        </ink:TabStrip>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
