<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Ink.Demo"
             xmlns:converters="clr-namespace:Ink.UI.Converters;assembly=Ink.UI"
             x:Class="Ink.Demo.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

     <Application.Resources>
         <converters:InkEqualsConverter x:Key="InkEqualsConverter" />
     </Application.Resources>

    <Application.Styles>
        <StyleInclude Source="avares://Ink.UI/Themes/InkTheme.axaml" />
        <StyleInclude Source="avares://Ink.DataGrid/Themes/DataGridTheme.axaml" />
    </Application.Styles>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

</Application>