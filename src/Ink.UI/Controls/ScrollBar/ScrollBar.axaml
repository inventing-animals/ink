<?xml version="1.0" encoding="utf-8"?>
<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Vertical -->
    <Style Selector="ScrollBar:vertical">
        <Setter Property="AllowAutoHide" Value="False" />
        <Setter Property="Width" Value="10" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="Transparent" UseLayoutRounding="False">
                    <Track
                        IsDirectionReversed="True"
                        Maximum="{TemplateBinding Maximum}"
                        Minimum="{TemplateBinding Minimum}"
                        Orientation="{TemplateBinding Orientation}"
                        Value="{TemplateBinding Value, Mode=TwoWay}"
                        ViewportSize="{TemplateBinding ViewportSize}">
                        <Track.DecreaseButton>
                            <RepeatButton
                                Name="PART_PageUpButton"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False" />
                        </Track.DecreaseButton>
                        <Track.IncreaseButton>
                            <RepeatButton
                                Name="PART_PageDownButton"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False" />
                        </Track.IncreaseButton>
                        <Thumb>
                            <Thumb.Template>
                                <ControlTemplate>
                                    <Panel>
                                        <Border
                                            Name="ThumbBar"
                                            Background="{DynamicResource Ink.Brush.Border.Strong}"
                                            CornerRadius="{DynamicResource Ink.CornerRadius.Pill}"
                                            Width="2"
                                            Margin="0,8"
                                            HorizontalAlignment="Center">
                                            <Border.Transitions>
                                                <Transitions>
                                                    <BrushTransition Duration="0:0:0.15" Property="Background" />
                                                    <DoubleTransition Duration="0:0:0.10" Property="Width" />
                                                    <ThicknessTransition Duration="0:0:0.10" Property="Margin" />
                                                </Transitions>
                                            </Border.Transitions>
                                        </Border>
                                    </Panel>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Horizontal -->
    <Style Selector="ScrollBar:horizontal">
        <Setter Property="AllowAutoHide" Value="False" />
        <Setter Property="Height" Value="10" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="Transparent" UseLayoutRounding="False">
                    <Track
                        IsDirectionReversed="False"
                        Maximum="{TemplateBinding Maximum}"
                        Minimum="{TemplateBinding Minimum}"
                        Orientation="{TemplateBinding Orientation}"
                        Value="{TemplateBinding Value, Mode=TwoWay}"
                        ViewportSize="{TemplateBinding ViewportSize}">
                        <Track.DecreaseButton>
                            <RepeatButton
                                Name="PART_PageUpButton"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False" />
                        </Track.DecreaseButton>
                        <Track.IncreaseButton>
                            <RepeatButton
                                Name="PART_PageDownButton"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False" />
                        </Track.IncreaseButton>
                        <Thumb>
                            <Thumb.Template>
                                <ControlTemplate>
                                    <Panel>
                                        <Border
                                            Name="ThumbBar"
                                            Background="{DynamicResource Ink.Brush.Border.Strong}"
                                            CornerRadius="{DynamicResource Ink.CornerRadius.Pill}"
                                            Height="2"
                                            Margin="8,0"
                                            VerticalAlignment="Center">
                                            <Border.Transitions>
                                                <Transitions>
                                                    <BrushTransition Duration="0:0:0.15" Property="Background" />
                                                    <DoubleTransition Duration="0:0:0.10" Property="Height" />
                                                    <ThicknessTransition Duration="0:0:0.10" Property="Margin" />
                                                </Transitions>
                                            </Border.Transitions>
                                        </Border>
                                    </Panel>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Expand thumb on ScrollViewer hover -->
    <Style Selector="ScrollViewer:pointerover /template/ ScrollBar">
        <Setter Property="AllowAutoHide" Value="True" />
    </Style>

    <Style Selector="ScrollBar[AllowAutoHide=True] Border#ThumbBar:vertical">
        <Setter Property="Width" Value="6" />
        <Setter Property="Margin" Value="0,4" />
    </Style>
    <Style Selector="ScrollBar[AllowAutoHide=True] Border#ThumbBar:horizontal">
        <Setter Property="Height" Value="6" />
        <Setter Property="Margin" Value="4,0" />
    </Style>

</Styles>
