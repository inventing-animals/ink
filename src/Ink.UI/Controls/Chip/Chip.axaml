<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ink="clr-namespace:Ink.UI.Controls">

    <ControlTheme TargetType="ink:Chip" x:Key="Ink.ChipStyle">
        <Setter Property="FontFamily" Value="{DynamicResource Ink.FontFamily.Base}" />
        <Setter Property="FontSize" Value="{DynamicResource Ink.FontSize.S}" />
        <Setter Property="FontWeight" Value="{DynamicResource Ink.FontWeight.SemiBold}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="CornerRadius" Value="{DynamicResource Ink.CornerRadius.Pill}" />
        <Setter Property="Background" Value="{DynamicResource Ink.Brush.Surface.Overlay.Stronger}" />
        <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Content.Primary}" />
        <Setter Property="Focusable" Value="False" />

        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />

        <Setter Property="Template">
            <ControlTemplate>
                <Border
                    Name="RootBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Padding="{TemplateBinding Padding}">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Duration="0:0:0.15" Property="Background" />
                            <BrushTransition Duration="0:0:0.15" Property="BorderBrush" />
                        </Transitions>
                    </Border.Transitions>
                    <TextBlock
                        Name="PART_Label"
                        Text="{TemplateBinding Content}"
                        FontFamily="{TemplateBinding FontFamily}"
                        FontSize="{TemplateBinding FontSize}"
                        FontWeight="{TemplateBinding FontWeight}"
                        Foreground="{TemplateBinding Foreground}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource Ink.Disabled.Opacity}" />
        </Style>

        <!-- ── Flat: structural ─────────────────────────────── -->
        <Style Selector="^.ink-chip-flat">
            <Setter Property="Background" Value="{DynamicResource Ink.Brush.Surface.Overlay.Stronger}" />
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Content.Primary}" />
        </Style>

        <!-- Flat: role colors (combined class - avoids compound selectors) -->
        <Style Selector="^.ink-chip-flat-primary">
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Accent.Text}" />
        </Style>
        <Style Selector="^.ink-chip-flat-danger">
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Danger.Text}" />
        </Style>
        <Style Selector="^.ink-chip-flat-warning">
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Warning.Text}" />
        </Style>
        <Style Selector="^.ink-chip-flat-success">
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Success.Text}" />
        </Style>

        <!-- ── Filled: structural ────────────────────────────── -->
        <Style Selector="^.ink-chip-filled">
            <Setter Property="Background" Value="{DynamicResource Ink.Brush.Surface.Overlay.Stronger}" />
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Content.Primary}" />
        </Style>

        <!-- Filled: role colors -->
        <Style Selector="^.ink-chip-filled-primary">
            <Setter Property="Background" Value="{DynamicResource Ink.Brush.Accent}" />
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Accent.Content}" />
        </Style>
        <Style Selector="^.ink-chip-filled-danger">
            <Setter Property="Background" Value="{DynamicResource Ink.Brush.Danger}" />
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Danger.Content}" />
        </Style>
        <Style Selector="^.ink-chip-filled-warning">
            <Setter Property="Background" Value="{DynamicResource Ink.Brush.Warning}" />
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Warning.Content}" />
        </Style>
        <Style Selector="^.ink-chip-filled-success">
            <Setter Property="Background" Value="{DynamicResource Ink.Brush.Success}" />
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Success.Content}" />
        </Style>

        <!-- ── Outline: structural ───────────────────────────── -->
        <Style Selector="^.ink-chip-outline">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Content.Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Ink.Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="{DynamicResource Ink.Stroke.Thick}" />
        </Style>

        <!-- Outline: role colors -->
        <Style Selector="^.ink-chip-outline-primary">
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Ink.Brush.Accent}" />
        </Style>
        <Style Selector="^.ink-chip-outline-danger">
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Danger}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Ink.Brush.Danger}" />
        </Style>
        <Style Selector="^.ink-chip-outline-warning">
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Warning}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Ink.Brush.Warning}" />
        </Style>
        <Style Selector="^.ink-chip-outline-success">
            <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Success}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Ink.Brush.Success}" />
        </Style>
    </ControlTheme>

    <ControlTheme BasedOn="{StaticResource Ink.ChipStyle}" TargetType="ink:Chip" x:Key="{x:Type ink:Chip}" />

</ResourceDictionary>
