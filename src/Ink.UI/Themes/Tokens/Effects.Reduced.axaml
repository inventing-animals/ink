<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Boolean x:Key="Ink.Effects.ShadowsEnabled">False</x:Boolean>
    <x:Boolean x:Key="Ink.Effects.BlurEnabled">False</x:Boolean>

    <x:Int32 x:Key="Ink.Elevation.Level0">0</x:Int32>
    <x:Int32 x:Key="Ink.Elevation.Level1">0</x:Int32>
    <x:Int32 x:Key="Ink.Elevation.Level2">0</x:Int32>
    <x:Int32 x:Key="Ink.Elevation.Level3">0</x:Int32>

    <x:Double x:Key="Ink.FocusRing.Thickness">2</x:Double>
    <x:Double x:Key="Ink.FocusRing.OuterGlow">0</x:Double>

    <x:Double x:Key="Ink.Disabled.Opacity">0.60</x:Double>

</ResourceDictionary>