<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neutral (dark theme): 0 = darkest, 12 = lightest -->
    <Color x:Key="Ink.Palette.Neutral.0">#FF050A14</Color>
    <Color x:Key="Ink.Palette.Neutral.1">#FF0B1220</Color>
    <Color x:Key="Ink.Palette.Neutral.2">#FF111827</Color>
    <Color x:Key="Ink.Palette.Neutral.3">#FF1F2937</Color>
    <Color x:Key="Ink.Palette.Neutral.4">#FF334155</Color>
    <Color x:Key="Ink.Palette.Neutral.5">#FF475569</Color>
    <Color x:Key="Ink.Palette.Neutral.6">#FF64748B</Color>
    <Color x:Key="Ink.Palette.Neutral.7">#FF94A3B8</Color>
    <Color x:Key="Ink.Palette.Neutral.8">#FFCBD5E1</Color>
    <Color x:Key="Ink.Palette.Neutral.9">#FFE2E8F0</Color>
    <Color x:Key="Ink.Palette.Neutral.10">#FFF1F5F9</Color>
    <Color x:Key="Ink.Palette.Neutral.11">#FFF8FAFC</Color>
    <Color x:Key="Ink.Palette.Neutral.12">#FFFFFFFF</Color>

    <!-- Primary -->
    <Color x:Key="Ink.Palette.Primary.3">#FF1D4ED8</Color>
    <Color x:Key="Ink.Palette.Primary.5">#FF3B82F6</Color>
    <Color x:Key="Ink.Palette.Primary.6">#FF60A5FA</Color>
    <Color x:Key="Ink.Palette.Primary.7">#FF93C5FD</Color>
    <Color x:Key="Ink.Palette.Primary.8">#FFBFDBFE</Color>

    <!-- Danger -->
    <Color x:Key="Ink.Palette.Danger.3">#FFB91C1C</Color>
    <Color x:Key="Ink.Palette.Danger.6">#FFEF4444</Color>
    <Color x:Key="Ink.Palette.Danger.7">#FFF87171</Color>
    <Color x:Key="Ink.Palette.Danger.8">#FFFCA5A5</Color>

</ResourceDictionary>