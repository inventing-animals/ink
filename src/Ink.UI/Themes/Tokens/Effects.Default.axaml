<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Boolean x:Key="Ink.Effects.ShadowsEnabled">True</x:Boolean>
    <x:Boolean x:Key="Ink.Effects.BlurEnabled">True</x:Boolean>

    <!-- Elevation levels (kept abstract; semantics/components will interpret them) -->
    <x:Int32 x:Key="Ink.Elevation.Level0">0</x:Int32>
    <x:Int32 x:Key="Ink.Elevation.Level1">1</x:Int32>
    <x:Int32 x:Key="Ink.Elevation.Level2">2</x:Int32>
    <x:Int32 x:Key="Ink.Elevation.Level3">3</x:Int32>

    <!-- Focus ring -->
    <x:Double x:Key="Ink.FocusRing.Thickness">2</x:Double>
    <x:Double x:Key="Ink.FocusRing.OuterGlow">6</x:Double>

    <!-- Disabled appearance -->
    <x:Double x:Key="Ink.Disabled.Opacity">0.5</x:Double>

</ResourceDictionary>