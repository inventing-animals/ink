<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Font families -->
    <FontFamily x:Key="Ink.FontFamily.Base">fonts:Inter#Inter</FontFamily>
    <FontFamily x:Key="Ink.FontFamily.Mono">Cascadia Mono, Consolas, Menlo</FontFamily>

    <!-- Font sizes -->
    <x:Double x:Key="Ink.FontSize.Xs">12</x:Double>
    <x:Double x:Key="Ink.FontSize.S">13</x:Double>
    <x:Double x:Key="Ink.FontSize.M">14</x:Double>
    <x:Double x:Key="Ink.FontSize.L">16</x:Double>
    <x:Double x:Key="Ink.FontSize.Xl">20</x:Double>
    <x:Double x:Key="Ink.FontSize.Xxl">24</x:Double>
    <x:Double x:Key="Ink.FontSize.Xxxl">30</x:Double>
    <x:Double x:Key="Ink.FontSize.Display">36</x:Double>

    <!-- Font weights -->
    <FontWeight x:Key="Ink.FontWeight.Regular">400</FontWeight>
    <FontWeight x:Key="Ink.FontWeight.Medium">500</FontWeight>
    <FontWeight x:Key="Ink.FontWeight.SemiBold">600</FontWeight>
    <FontWeight x:Key="Ink.FontWeight.Bold">700</FontWeight>

    <!-- Line heights (multipliers) -->
    <x:Double x:Key="Ink.LineHeight.Tight">1.10</x:Double>
    <x:Double x:Key="Ink.LineHeight.Normal">1.25</x:Double>
    <x:Double x:Key="Ink.LineHeight.Relaxed">1.40</x:Double>

</ResourceDictionary>