<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neutral (light theme): 0 = whitest, 12 = darkest -->
    <Color x:Key="Ink.Palette.Neutral.0">#FFFFFFFF</Color>
    <Color x:Key="Ink.Palette.Neutral.1">#FFF8FAFC</Color>
    <Color x:Key="Ink.Palette.Neutral.2">#FFF1F5F9</Color>
    <Color x:Key="Ink.Palette.Neutral.3">#FFE2E8F0</Color>
    <Color x:Key="Ink.Palette.Neutral.4">#FFCBD5E1</Color>
    <Color x:Key="Ink.Palette.Neutral.5">#FF94A3B8</Color>
    <Color x:Key="Ink.Palette.Neutral.6">#FF64748B</Color>
    <Color x:Key="Ink.Palette.Neutral.7">#FF475569</Color>
    <Color x:Key="Ink.Palette.Neutral.8">#FF334155</Color>
    <Color x:Key="Ink.Palette.Neutral.9">#FF1F2937</Color>
    <Color x:Key="Ink.Palette.Neutral.10">#FF111827</Color>
    <Color x:Key="Ink.Palette.Neutral.11">#FF0B1220</Color>
    <Color x:Key="Ink.Palette.Neutral.12">#FF050A14</Color>

    <!-- Primary (blue-ish) -->
    <Color x:Key="Ink.Palette.Primary.3">#FFDBEAFE</Color>
    <Color x:Key="Ink.Palette.Primary.5">#FF60A5FA</Color>
    <Color x:Key="Ink.Palette.Primary.6">#FF3B82F6</Color>
    <Color x:Key="Ink.Palette.Primary.7">#FF2563EB</Color>
    <Color x:Key="Ink.Palette.Primary.8">#FF1D4ED8</Color>

    <!-- Danger (red-ish) -->
    <Color x:Key="Ink.Palette.Danger.3">#FFFEE2E2</Color>
    <Color x:Key="Ink.Palette.Danger.6">#FFEF4444</Color>
    <Color x:Key="Ink.Palette.Danger.7">#FFDC2626</Color>
    <Color x:Key="Ink.Palette.Danger.8">#FFB91C1C</Color>

</ResourceDictionary>