<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Relative named colors: dark theme.
        Scale is inverted: .50 maps to the darkest shade, .950 to the lightest.
        This preserves visual intent across themes: .200 always reads as a subtle
        tint regardless of whether the background is light or dark.

        Inversion map:  50↔950  100↔900  200↔800  300↔700  400↔600  500=500
                        Foreground ↔ Foreground.Subtle
    -->

    <!-- ── Gray ──────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Ink.Color.Gray.50"  Color="{DynamicResource Ink.Color.Fixed.Gray.950}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.100" Color="{DynamicResource Ink.Color.Fixed.Gray.900}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.200" Color="{DynamicResource Ink.Color.Fixed.Gray.800}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.300" Color="{DynamicResource Ink.Color.Fixed.Gray.700}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.400" Color="{DynamicResource Ink.Color.Fixed.Gray.600}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.500" Color="{DynamicResource Ink.Color.Fixed.Gray.500}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.600" Color="{DynamicResource Ink.Color.Fixed.Gray.400}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.700" Color="{DynamicResource Ink.Color.Fixed.Gray.300}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.800" Color="{DynamicResource Ink.Color.Fixed.Gray.200}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.900" Color="{DynamicResource Ink.Color.Fixed.Gray.100}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.950" Color="{DynamicResource Ink.Color.Fixed.Gray.50}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.Foreground"        Color="{DynamicResource Ink.Color.Fixed.Gray.Foreground.Subtle}" />
    <SolidColorBrush x:Key="Ink.Color.Gray.Foreground.Subtle" Color="{DynamicResource Ink.Color.Fixed.Gray.Foreground}" />

