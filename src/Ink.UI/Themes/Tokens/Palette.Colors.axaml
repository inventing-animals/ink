<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Fixed named color palette: theme-independent, Tailwind-sourced hex values.
        Shades: 50 (lightest) → 950 (darkest), 11 stops per color.

        Use Ink.Color.Fixed.* when you need a specific absolute shade regardless of theme.
        Use Ink.Color.Relative.* when you want consistent visual weight across themes
        (the scale inverts in dark mode so .200 always reads as a subtle tint).

        Foreground pairing rule (Fixed):
          • shades  50–400  →  {DynamicResource Ink.Color.Fixed.X.Foreground}        (dark text)
          • shades 500–950  →  {DynamicResource Ink.Color.Fixed.X.Foreground.Subtle} (light text)
    -->

    <!-- ── Gray ──────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.50"  Color="#FFF8FAFC" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.100" Color="#FFF1F5F9" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.200" Color="#FFE2E8F0" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.300" Color="#FFCBD5E1" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.400" Color="#FF94A3B8" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.500" Color="#FF64748B" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.600" Color="#FF475569" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.700" Color="#FF334155" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.800" Color="#FF1E293B" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.900" Color="#FF0F172A" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.950" Color="#FF020617" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.Foreground"        Color="#FF020617" />
    <SolidColorBrush x:Key="Ink.Color.Fixed.Gray.Foreground.Subtle" Color="#FFF8FAFC" />

