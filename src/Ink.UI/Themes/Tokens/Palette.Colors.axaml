    <Color x:Key="Ink.Color.Fixed.Gray.800">#FF27272A</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.850">#FF262728</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.870">#FF232325</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.900">#FF18181B</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.950">#FF060607</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.Foreground">#FF18181B</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.Foreground.Subtle">#FFFCFCFC</Color>

