<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Fixed named color palette: theme-independent, Tailwind-sourced hex values.
        Shades: 50 (lightest) → 950 (darkest), 11 stops per color.

        Use Ink.Color.Fixed.* when you need a specific absolute shade regardless of theme.
        Use Ink.Color.Relative.* when you want consistent visual weight across themes
        (the scale inverts in dark mode so .200 always reads as a subtle tint).

        Foreground pairing rule (Fixed):
          • shades  50–400  →  {DynamicResource Ink.Color.Fixed.X.Foreground}        (dark text)
          • shades 500–950  →  {DynamicResource Ink.Color.Fixed.X.Foreground.Subtle} (light text)
    -->

    <!-- ── Gray (Zinc) ───────────────────────────────────────────── -->
    <Color x:Key="Ink.Color.Fixed.White">#FFFFFFFF</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.50">#FFFAFAFA</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.100">#FFF4F4F5</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.200">#FFE4E4E7</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.300">#FFD4D4D8</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.400">#FFA1A1AA</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.500">#FF71717A</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.600">#FF52525B</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.700">#FF3F3F46</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.800">#FF27272A</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.900">#FF18181B</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.950">#FF000000</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.Foreground">#FF18181B</Color>
    <Color x:Key="Ink.Color.Fixed.Gray.Foreground.Subtle">#FFFAFAFA</Color>

