    <SolidColorBrush x:Key="Ink.Color.Blue.500" Color="#FF3B82F6" />
    <SolidColorBrush x:Key="Ink.Color.Blue.600" Color="#FF2563EB" />
    <SolidColorBrush x:Key="Ink.Color.Blue.700" Color="#FF1D4ED8" />
    <SolidColorBrush x:Key="Ink.Color.Blue.800" Color="#FF1E40AF" />
    <SolidColorBrush x:Key="Ink.Color.Blue.900" Color="#FF1E3A8A" />
    <SolidColorBrush x:Key="Ink.Color.Blue.950" Color="#FF172554" />
