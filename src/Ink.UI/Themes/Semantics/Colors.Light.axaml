<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ========================= -->
  <!-- Surfaces                  -->
  <!-- ========================= -->

  <SolidColorBrush x:Key="Ink.Brush.Surface.Canvas"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.50}" />

  <SolidColorBrush x:Key="Ink.Brush.Surface.Panel"
                   Color="{DynamicResource Ink.Color.Fixed.White}" />

  <SolidColorBrush x:Key="Ink.Brush.Surface.Raised"
                   Color="{DynamicResource Ink.Color.Fixed.White}" />

  <SolidColorBrush x:Key="Ink.Brush.Surface.Dialog"
                   Color="{DynamicResource Ink.Color.Fixed.White}" />

  <SolidColorBrush x:Key="Ink.Brush.Surface.Overlay.Subtle"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.100}" />

  <SolidColorBrush x:Key="Ink.Brush.Surface.Overlay.Stronger"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.200}" />

  <!-- ========================= -->
  <!-- Content (text/icons)      -->
  <!-- ========================= -->

  <SolidColorBrush x:Key="Ink.Brush.Content.Primary"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.900}" />

  <SolidColorBrush x:Key="Ink.Brush.Content.Secondary"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.600}" />

  <SolidColorBrush x:Key="Ink.Brush.Content.Muted"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.500}" />

  <SolidColorBrush x:Key="Ink.Brush.Content.Inverse"
                   Color="{DynamicResource Ink.Color.Fixed.White}" />

  <SolidColorBrush x:Key="Ink.Brush.Content.Disabled"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.500}" />

  <!-- ========================= -->
  <!-- Borders / dividers        -->
  <!-- ========================= -->

  <SolidColorBrush x:Key="Ink.Brush.Border.Subtle"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.200}" />

  <SolidColorBrush x:Key="Ink.Brush.Border.Strong"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.300}" />

  <SolidColorBrush x:Key="Ink.Brush.Divider"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.100}" />

  <!-- ========================= -->
  <!-- Accent (primary)          -->
  <!-- ========================= -->

  <SolidColorBrush x:Key="Ink.Brush.Accent"
                   Color="{DynamicResource Ink.Color.Fixed.Blue.500}" />

  <SolidColorBrush x:Key="Ink.Brush.Accent.Hover"
                   Color="{DynamicResource Ink.Color.Fixed.Blue.600}" />

  <SolidColorBrush x:Key="Ink.Brush.Accent.Pressed"
                   Color="{DynamicResource Ink.Color.Fixed.Blue.700}" />

  <SolidColorBrush x:Key="Ink.Brush.Accent.Subtle"
                   Color="{DynamicResource Ink.Color.Fixed.Blue.100}" />

  <SolidColorBrush x:Key="Ink.Brush.Accent.Content"
                   Color="{DynamicResource Ink.Color.Fixed.White}" />

  <!-- focus: same as accent -->
  <SolidColorBrush x:Key="Ink.Brush.FocusRing"
                   Color="{DynamicResource Ink.Color.Fixed.Blue.500}" />

  <!-- ========================= -->
  <!-- Status: Danger            -->
  <!-- ========================= -->

  <SolidColorBrush x:Key="Ink.Brush.Danger"
                   Color="{DynamicResource Ink.Color.Fixed.Red.500}" />

  <SolidColorBrush x:Key="Ink.Brush.Danger.Hover"
                   Color="{DynamicResource Ink.Color.Fixed.Red.600}" />

  <SolidColorBrush x:Key="Ink.Brush.Danger.Subtle"
                   Color="{DynamicResource Ink.Color.Fixed.Red.100}" />

  <SolidColorBrush x:Key="Ink.Brush.Danger.Content"
                   Color="{DynamicResource Ink.Color.Fixed.White}" />

  <!-- ========================= -->
  <!-- Inputs                    -->
  <!-- ========================= -->

  <SolidColorBrush x:Key="Ink.Brush.Input.Background"
                   Color="{DynamicResource Ink.Color.Fixed.White}" />

  <!-- field-border: visible border since Avalonia has no box-shadow -->
  <SolidColorBrush x:Key="Ink.Brush.Input.Border"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.200}" />

  <SolidColorBrush x:Key="Ink.Brush.Input.Border.Hover"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.300}" />

  <SolidColorBrush x:Key="Ink.Brush.Input.Border.Focused"
                   Color="{DynamicResource Ink.Color.Fixed.Blue.500}" />

  <SolidColorBrush x:Key="Ink.Brush.Input.Placeholder"
                   Color="{DynamicResource Ink.Color.Fixed.Gray.500}" />

</ResourceDictionary>
