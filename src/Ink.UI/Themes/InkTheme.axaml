<?xml version="1.0" encoding="utf-8"?>
<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Ink.UI.Controls"
    x:Class="Ink.UI.Themes.InkTheme">

    <!-- Always-loaded token dictionaries -->
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Ink.UI/Themes/Tokens/Metrics.axaml" />
                <ResourceInclude Source="avares://Ink.UI/Themes/Tokens/Typography.axaml" />
                <ResourceInclude Source="avares://Ink.UI/Themes/Tokens/Palette.Colors.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <!-- Light -->
    <Style Selector=":is(Styles).Light">
        <Style.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceInclude Source="avares://Ink.UI/Themes/Tokens/Palette.Light.axaml" />
                    <ResourceInclude Source="avares://Ink.UI/Themes/Semantics/Colors.Light.axaml" />
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </Style.Resources>
    </Style>

    <!-- Dark -->
    <Style Selector=":is(Styles).Dark">
        <Style.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceInclude Source="avares://Ink.UI/Themes/Tokens/Palette.Dark.axaml" />
                    <ResourceInclude Source="avares://Ink.UI/Themes/Semantics/Colors.Dark.axaml" />
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </Style.Resources>
    </Style>

    <!-- Base element defaults -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource Ink.Brush.Surface.Canvas}" />
    </Style>
    <Style Selector="controls|WebWindow">
        <Setter Property="Background" Value="{DynamicResource Ink.Brush.Surface.Canvas}" />
    </Style>
    <Style Selector="controls|MobileWindow">
        <Setter Property="Background" Value="{DynamicResource Ink.Brush.Surface.Canvas}" />
    </Style>
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Content.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Ink.FontFamily.Base}" />
        <Setter Property="FontSize" Value="{DynamicResource Ink.FontSize.M}" />
    </Style>

    <!-- Controls -->
    <StyleInclude Source="avares://Ink.UI/Controls/Button/Button.axaml" />

</Styles>