<?xml version="1.0" encoding="utf-8"?>
<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Ink.DataGrid.Controls">

    <!-- ================================ -->
    <!-- DataGrid control                 -->
    <!-- ================================ -->
    <Style Selector="controls|DataGrid">
        <Setter Property="Background" Value="{DynamicResource Ink.Brush.Surface.Panel}" />
        <Setter Property="CornerRadius" Value="{DynamicResource Ink.CornerRadius.L}" />

        <Setter Property="Template">
            <ControlTemplate>
                <!-- Outer shell: secondary background that peeks through as a frame -->
                <Border
                    Background="{DynamicResource Ink.Brush.Surface.Overlay.Subtle}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    BoxShadow="{DynamicResource Ink.Shadow.Surface}"
                    ClipToBounds="False"
                    Padding="6">
                    <DockPanel>
                        <!-- Header row: sits on the outer (lower) layer -->
                        <Panel x:Name="PART_Header" DockPanel.Dock="Top" />

                        <!-- Inner content area: rows get their own rounded surface -->
                        <Border
                            Background="{TemplateBinding Background}"
                            CornerRadius="{DynamicResource Ink.CornerRadius.M}"
                            ClipToBounds="True">
                            <ScrollViewer
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="PART_Body" />
                            </ScrollViewer>
                        </Border>
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- ================================ -->
    <!-- Header cells                     -->
    <!-- ================================ -->
    <Style Selector="controls|DataGrid Border.ink-datagrid-header-cell">
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="controls|DataGrid TextBlock.ink-datagrid-header-text">
        <Setter Property="FontWeight" Value="{DynamicResource Ink.FontWeight.SemiBold}" />
        <Setter Property="FontSize" Value="{DynamicResource Ink.FontSize.XS}" />
        <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Content.Muted}" />
    </Style>

    <!-- ================================ -->
    <!-- Data rows                        -->
    <!-- ================================ -->
    <Style Selector="controls|DataGrid Border.ink-datagrid-row">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource Ink.Brush.Divider}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Duration="0:0:0.15" Property="Background" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="controls|DataGrid Border.ink-datagrid-row:pointerover">
        <Setter Property="Background" Value="{DynamicResource Ink.Brush.Surface.Overlay.Subtle}" />
    </Style>

    <!-- Last row: remove bottom divider so it sits clean against the rounded inner border -->
    <Style Selector="controls|DataGrid Border.ink-datagrid-row:nth-last-child(1)">
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- ================================ -->
    <!-- Data cells                       -->
    <!-- ================================ -->
    <Style Selector="controls|DataGrid Border.ink-datagrid-cell">
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="controls|DataGrid TextBlock.ink-datagrid-cell-text">
        <Setter Property="FontSize" Value="{DynamicResource Ink.FontSize.S}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- ================================ -->
    <!-- Interactive header cell          -->
    <!-- ================================ -->
    <Style Selector="controls|DataGrid Border.ink-datagrid-header-cell-interactive">
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="controls|DataGrid TextBlock.ink-datagrid-sort-indicator">
        <Setter Property="FontSize" Value="{DynamicResource Ink.FontSize.XS}" />
        <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Content.Muted}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ================================ -->
    <!-- Column header popup              -->
    <!-- ================================ -->
    <Style Selector="Border.ink-datagrid-popup-title">
        <Setter Property="Padding" Value="12,10,12,10" />
    </Style>

    <Style Selector="TextBlock.ink-datagrid-popup-title-text">
        <Setter Property="FontWeight" Value="{DynamicResource Ink.FontWeight.SemiBold}" />
        <Setter Property="FontSize" Value="{DynamicResource Ink.FontSize.S}" />
        <Setter Property="Foreground" Value="{DynamicResource Ink.Brush.Content.Secondary}" />
    </Style>

    <Style Selector="Border.ink-datagrid-popup-separator">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource Ink.Brush.Divider}" />
    </Style>

    <Style Selector="Button.ink-datagrid-popup-item">
        <Setter Property="Padding" Value="12,8,12,8" />
        <Setter Property="FontSize" Value="{DynamicResource Ink.FontSize.S}" />
        <Setter Property="MinHeight" Value="0" />
    </Style>

    <Style Selector="Border.ink-datagrid-popup-filter">
        <Setter Property="Padding" Value="12,10,12,10" />
    </Style>

    <Style Selector="StackPanel.ink-datagrid-popup-footer">
        <Setter Property="Margin" Value="12,8,12,10" />
    </Style>

</Styles>
